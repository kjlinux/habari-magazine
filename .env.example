# ============================================================
# HABARI MAGAZINE — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# --- Base de données ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/habari_db

# --- Auth JWT (générer avec: openssl rand -hex 64) ---
JWT_SECRET=your_jwt_secret_here

# --- Domaine de l'application ---
APP_URL=https://habarimag.online

# --- Stripe (créer un projet sur dashboard.stripe.com) ---
# Clé secrète : Developers > API keys > Secret key
STRIPE_SECRET_KEY=sk_live_...

# Clé publique : Developers > API keys > Publishable key
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook secret : Developers > Webhooks > Signing secret
# Endpoint à configurer : https://habarimag.online/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Serveur ---
PORT=3000
NODE_ENV=production
