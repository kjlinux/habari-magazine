# ============================================================
# HABARI MAGAZINE — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# --- Base de données ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/habari_db

# --- Auth JWT (générer avec: openssl rand -hex 64) ---
JWT_SECRET=your_jwt_secret_here

# --- Domaine de l'application ---
APP_URL=https://habarimag.online

# --- Stripe (créer un projet sur dashboard.stripe.com) ---
# Clé restreinte : Developers > API keys > Create restricted key
# Permissions requises : Checkout Sessions (Write), Customers (Write),
# Subscriptions (Write), Invoices (Read), Payment Intents (Read),
# Charges (Read), Products (Read), Prices (Read)
STRIPE_RESTRICTED_KEY=rk_live_...

# Clé publique : Developers > API keys > Publishable key
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook secret : Developers > Webhooks > Signing secret
# Endpoint à configurer : https://habarimag.online/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# --- OpenAI (génération d'images DALL-E) ---
# Obtenir sur platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- Serveur ---
PORT=3000
NODE_ENV=production
